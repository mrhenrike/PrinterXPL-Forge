{
  "_comment": [
    "PrinterReaper — Configuration Template",
    "Copy this file to config.json and fill in your credentials.",
    "config.json is gitignored — NEVER commit real credentials.",
    "",
    "Features that require credentials:",
    "  shodan    -> --discover-online (Shodan dork queries)",
    "  censys    -> --discover-online (Censys dork queries)",
    "  fofa      -> --discover-online --dork-engine fofa",
    "  zoomeye   -> --discover-online --dork-engine zoomeye",
    "  netlas    -> --discover-online --dork-engine netlas",
    "  nvd       -> --scan CVE lookup (higher rate limit; works without key too)",
    "  openai    -> AI-assisted exploit analysis, report generation, summaries",
    "  anthropic -> Claude as alternative LLM for analysis and reports",
    "  gemini    -> Gemini as alternative LLM for analysis and reports",
    "",
    "Register for API keys:",
    "  Shodan    : https://account.shodan.io/",
    "  Censys    : https://search.censys.io/account/api",
    "  FOFA      : https://en.fofa.info/api",
    "  ZoomEye   : https://www.zoomeye.org/profile",
    "  Netlas    : https://app.netlas.io/profile/  (50 req/day free)",
    "  NVD       : https://nvd.nist.gov/developers/request-an-api-key",
    "  OpenAI    : https://platform.openai.com/api-keys",
    "  Anthropic : https://console.anthropic.com/settings/keys",
    "  Gemini    : https://aistudio.google.com/app/apikey"
  ],

  "shodan": [
    { "label": "primary",   "api_key": "YOUR_SHODAN_API_KEY" },
    { "label": "secondary", "api_key": "" }
  ],

  "censys": [
    { "label": "primary", "api_id": "YOUR_CENSYS_API_ID", "api_secret": "YOUR_CENSYS_API_SECRET" }
  ],

  "fofa": [
    { "label": "primary", "api_key": "YOUR_FOFA_API_KEY" }
  ],

  "zoomeye": [
    { "label": "primary", "api_key": "YOUR_ZOOMEYE_API_KEY" }
  ],

  "netlas": [
    { "label": "primary", "api_key": "YOUR_NETLAS_API_KEY" }
  ],

  "nvd": [
    { "label": "primary", "api_key": "YOUR_NVD_API_KEY" }
  ],

  "openai": [
    { "label": "primary",  "api_key": "YOUR_OPENAI_API_KEY", "model": "gpt-4o" },
    { "label": "fallback", "api_key": "",                    "model": "gpt-4o-mini" }
  ],

  "anthropic": [
    { "label": "primary", "api_key": "YOUR_ANTHROPIC_API_KEY", "model": "claude-opus-4-5" }
  ],

  "gemini": [
    { "label": "primary",   "api_key": "YOUR_GEMINI_API_KEY", "model": "gemini-2.0-flash" },
    { "label": "secondary", "api_key": "",                     "model": "gemini-2.0-flash" }
  ],

  "network": {
    "timeout": 5,
    "snmp_community": "public",
    "snmp_timeout": 2,
    "max_retries": 1
  },

  "ml": {
    "enabled": false,
    "model_dir": ".ml_models",
    "min_confidence": 0.60
  },

  "discovery": {
    "max_results_per_query": 50,
    "delay_between_queries": 1.5
  },

  "output": {
    "color": true,
    "verbose": false,
    "log_dir": ".log"
  }
}
