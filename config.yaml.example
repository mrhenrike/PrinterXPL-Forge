# PrinterReaper — Configuration Template
# =========================================
# Copy this file to config.yaml and fill in your credentials.
# The file config.yaml is gitignored and must never be committed.

shodan:
  api_key: "YOUR_SHODAN_API_KEY_HERE"   # https://account.shodan.io/

censys:
  api_id: ""         # https://search.censys.io/account/api
  api_secret: ""

nvd:
  api_key: ""        # optional — https://nvd.nist.gov/developers/request-an-api-key

network:
  timeout: 5
  snmp_community: "public"
  snmp_timeout: 2

ml:
  enabled: false
  model_dir: ".ml_models"
  min_confidence: 0.60

discovery:
  max_results_per_query: 50
  delay_between_queries: 1.5

output:
  color: true
  verbose: false
  log_dir: ".log"
