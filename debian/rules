#!/usr/bin/make -f
# Debian packaging rules for printer-reaper
# Build with:  dpkg-buildpackage -us -uc -b

export DH_VERBOSE = 1
export PYBUILD_NAME = printer-reaper

%:
	dh $@ --with python3 --buildsystem=pybuild

override_dh_auto_install:
	dh_auto_install
	# Install wordlists to /usr/share/printer-reaper/wordlists/
	install -d $(CURDIR)/debian/printer-reaper/usr/share/printer-reaper/wordlists
	install -m 644 wordlists/*.txt $(CURDIR)/debian/printer-reaper/usr/share/printer-reaper/wordlists/
	# Install exploit library to /usr/share/printer-reaper/xpl/
	install -d $(CURDIR)/debian/printer-reaper/usr/share/printer-reaper/xpl
	cp -r xpl/. $(CURDIR)/debian/printer-reaper/usr/share/printer-reaper/xpl/
	# Install config example
	install -d $(CURDIR)/debian/printer-reaper/usr/share/printer-reaper
	install -m 644 config.json.example \
	    $(CURDIR)/debian/printer-reaper/usr/share/printer-reaper/config.json.example
	# Install man page
	install -d $(CURDIR)/debian/printer-reaper/usr/share/man/man1
	install -m 644 man/man1/printer-reaper.1 \
	    $(CURDIR)/debian/printer-reaper/usr/share/man/man1/printer-reaper.1

override_dh_compress:
	dh_compress
	# Man pages are compressed automatically by dh_compress

override_dh_fixperms:
	dh_fixperms
	# Wordlists must be world-readable
	chmod 644 $(CURDIR)/debian/printer-reaper/usr/share/printer-reaper/wordlists/*.txt || true
